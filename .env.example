# Example .env for SyrLink
MONGO_URL="mongodb+srv://user:pass@cluster.mongodb.net/dbname"
DB_NAME="syrlink_db"
JWT_SECRET="your_super_secure_random_string_here"
JWT_EXPIRY_MIN="1440"
APP_URL="https://your-frontend.example.com"
CORS_ORIGINS="http://localhost:3000,https://your-frontend.example.com"
CLOUDINARY_CLOUD_NAME="your_cloudinary_name"
CLOUDINARY_API_KEY="your_cloudinary_key"
CLOUDINARY_API_SECRET="your_cloudinary_secret"
ADMIN_EMAIL="admin@syrlink.local"
ADMIN_PASSWORD="ChangeMeNow!"
REDIS_URL=""
SENTRY_DSN=""
JWT_COOKIE_NAME="li_token"
JWT_REFRESH_COOKIE_NAME="li_refresh"

# NOTE: Do NOT commit real secrets. Use a secrets manager in production.
